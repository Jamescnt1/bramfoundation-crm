NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only. Prefer the current sb_secret_ key from Supabase Settings > API Keys.
# Never prefix either variable with NEXT_PUBLIC and never commit the real value.
SUPABASE_SECRET_KEY=
# Legacy fallback supported for existing deployments.
SUPABASE_SERVICE_ROLE_KEY=

# Used only by npm run bootstrap:admin. Remove it after the administrator is created.
INITIAL_ADMIN_PASSWORD=

# Customer email (Resend). Verify EMAIL_FROM_ADDRESS in the provider first.
RESEND_API_KEY=
EMAIL_FROM_ADDRESS=
EMAIL_FROM_NAME=Bram Flooring

# Optional inbound reply handling. Configure this receiving domain and webhook
# /api/customer-email/webhook in Resend, then paste the webhook signing secret.
EMAIL_INBOUND_DOMAIN=
RESEND_WEBHOOK_SECRET=

# Optional company-dashboard attention thresholds.
COMPANY_DASHBOARD_FOLLOW_UP_DAYS=5
COMPANY_DASHBOARD_WAITING_APPROVAL_DAYS=7
